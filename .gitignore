ml/models/*.pkl
ml/data/raw/
ml/data/logs/
ml/data/processed/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Screenshots folder config (Playwright MCP local settings)
screenshots/settings.local.json

