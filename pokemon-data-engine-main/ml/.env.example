# ============================================================
# ML Pipeline Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- SQLite (local pipeline) ---
DB_PATH=../pokemon.db
CACHE_DIR=./data/raw
ASSIGNED_CSV_PATH=./data/csv/assigned_pokemon.csv
API_BASE_URL=https://pokeapi.co/api/v2
GEN_LIMIT=151

# --- Supabase PostgreSQL (seed_supabase.py) ---
# Get these from: Supabase Dashboard > Project Settings > Database > Connection string
# Use the "Session mode" pooler (port 5432) or "Transaction mode" (port 6543).
# For psycopg2 with direct connection, use port 5432 and your project host.
DB_HOST=aws-0-ap-southeast-2.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_password_here
DB_NAME=postgres
